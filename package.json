{
  "name": "mindes",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Mindes — простой mindmap с синхронизацией через Google.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "deploy": "vite build && firebase deploy --only hosting",
    "android:sync": "vite build && cap sync android",
    "android:open": "vite build && cap sync android && cap open android",
    "android:run": "vite build && cap sync android && cap run android",
    "android:dev": "cap run android -l --external",
    "apk": "vite build && cap sync android && cd android && gradlew.bat assembleDebug",
    "apk:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^6.3.1",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/local-notifications": "^6.1.1",
    "firebase": "^10.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}
